generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  firstName     String
  lastName      String
  role          Role      @default(VIEWER)
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  projects      ProjectMember[]
  documents     Document[]        @relation("DocumentOwner")
  documentVersions DocumentVersion[]
  createdProjects Project[]       @relation("ProjectCreator")
  activities    Activity[]
  notifications Notification[]
  auditLogs     AuditLog[]
  searchHistory SearchHistory[]
  chatSessions  ChatSession[]
  complianceChecks ComplianceCheck[]
  rfisRaised    Rfi[]             @relation("RfiRaisedBy")
  rfisAssigned  Rfi[]             @relation("RfiAssignee")
  rfisAnswered  Rfi[]             @relation("RfiAnsweredBy")
  agentRuns     AgentRun[]
  reports       Report[]          @relation("ReportGeneratedBy")
  simulationsCreated Simulation[] @relation("SimulationCreatedBy")
  ncrsRaised    Ncr[]             @relation("NcrRaisedBy")
  changeOrdersApproved ChangeOrder[] @relation("ChangeOrderApprovedBy")
  notificationPreference NotificationPreference?

  @@index([email])
  @@map("users")
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  code        String   @unique
  status      ProjectStatus @default(PLANNING)
  startDate   DateTime?
  endDate     DateTime?
  location    String?
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creatorId   String
  creator     User     @relation("ProjectCreator", fields: [creatorId], references: [id])
  members       ProjectMember[]
  documents     Document[]
  activities    Activity[]
  searchHistory SearchHistory[]
  chatSessions  ChatSession[]
  complianceChecks ComplianceCheck[]
  scheduleActivities ScheduleActivity[]
  scheduleImports    ScheduleImport[]
  vendors            Vendor[]
  procurementItems   ProcurementItem[]
  rfis               Rfi[]
  agentRuns          AgentRun[]
  agentSchedules     AgentSchedule[]
  reports            Report[]
  simulations        Simulation[]
  ncrs               Ncr[]
  inspections        Inspection[]
  commissioningRecords CommissioningRecord[]
  changeOrders       ChangeOrder[]

  @@index([code])
  @@index([status])
  @@map("projects")
}

model ProjectMember {
  id        String       @id @default(cuid())
  role      ProjectRole  @default(MEMBER)
  joinedAt  DateTime     @default(now())

  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId String
  project   Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@map("project_members")
}

model Document {
  id            String        @id @default(cuid())
  filename      String
  originalName  String
  mimeType      String
  size          Int
  category      String        @default("uncategorized")
  path          String
  bucket        String
  status        DocumentStatus @default(QUEUED)
  metadata      Json?
  pageCount     Int?
  extractedText String?
  summary       String?
  uploadedAt    DateTime      @default(now())
  processedAt   DateTime?
  completedAt   DateTime?
  deletedAt     DateTime?

  projectId     String
  project       Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  ownerId       String
  owner         User          @relation("DocumentOwner", fields: [ownerId], references: [id])
  chunks        DocumentChunk[]
  versions      DocumentVersion[]
  rfiLinks      RfiDocument[]
  ncrs          Ncr[]
  inspections   Inspection[]
  commissioningRecords CommissioningRecord[]
  changeOrders  ChangeOrder[]

  @@index([projectId])
  @@index([status])
  @@index([category])
  @@index([ownerId])
  @@index([deletedAt])
  @@map("documents")
}

model DocumentVersion {
  id           String   @id @default(cuid())
  version      Int
  filename     String
  originalName String
  mimeType     String
  size         Int
  path         String
  bucket       String
  metadata     Json?
  createdAt    DateTime @default(now())

  documentId   String
  document     Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  uploadedById String
  uploadedBy   User     @relation(fields: [uploadedById], references: [id])

  @@unique([documentId, version])
  @@index([documentId])
  @@index([uploadedById])
  @@map("document_versions")
}

model DocumentChunk {
  id          String   @id @default(cuid())
  content     String
  embedding   Unsupported("vector")?
  chunkIndex  Int
  tokenCount  Int
  metadata    Json?
  createdAt   DateTime @default(now())

  documentId  String
  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, chunkIndex])
  @@index([documentId])
  @@map("document_chunks")
}

model Activity {
  id          String        @id @default(cuid())
  type        ActivityType
  title       String
  description String?
  metadata    Json?
  createdAt   DateTime      @default(now())

  projectId   String
  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([userId])
  @@index([createdAt])
  @@map("activities")
}

model Notification {
  id        String              @id @default(cuid())
  type      NotificationType
  title     String
  message   String
  link      String?
  data      Json?
  read      Boolean             @default(false)
  readAt    DateTime?
  createdAt DateTime            @default(now())

  userId    String
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
  @@index([createdAt])
  @@map("notifications")
}

model AuditLog {
  id           String   @id @default(cuid())
  action       String
  resourceType String?
  resourceId   String?
  details      Json?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  userId       String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_log")
}

enum Role {
  ADMIN
  PROJECT_MANAGER
  ENGINEER
  PROCUREMENT
  QA_QC
  VIEWER
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  ARCHIVED
}

enum ProjectRole {
  OWNER
  MANAGER
  ENGINEER
  PROCUREMENT
  QA_QC
  MEMBER
  VIEWER
}

enum DocumentStatus {
  QUEUED
  UPLOADED
  PROCESSING
  PROCESSED
  FAILED
  ARCHIVED
}

enum ActivityType {
  DOCUMENT_UPLOADED
  DOCUMENT_PROCESSED
  COMPLIANCE_CHECKED
  SCHEDULE_UPDATED
  PROCUREMENT_CREATED
  RFI_CREATED
  NCR_CREATED
  INSPECTION_SCHEDULED
  USER_JOINED
  COMMENT_ADDED
}

enum NotificationType {
  INFO
  WARNING
  ERROR
  SUCCESS
  TASK_ASSIGNED
  DEADLINE_APPROACHING
  COMPLIANCE_ISSUE
  DOCUMENT_READY
}

model SearchHistory {
  id          String   @id @default(cuid())
  query       String
  resultCount Int      @default(0)
  cached      Boolean  @default(false)
  filters     Json?
  createdAt   DateTime @default(now())

  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([userId])
  @@index([createdAt])
  @@map("search_history")
}

model ComplianceCheck {
  id               String   @id @default(cuid())
  status           String   @default("COMPLETED")
  complianceScore  Int      @default(0)
  standards        Json?
  findings         Json?
  summary          Json?
  notes            String?
  documentIds      Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  projectId        String
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  ownerId          String
  owner            User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([ownerId])
  @@index([createdAt])
  @@map("compliance_checks")
}

model ChatSession {
  id        String   @id @default(cuid())
  title     String   @default("New Chat")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  ChatMessage[]

  @@index([projectId])
  @@index([userId])
  @@index([updatedAt])
  @@map("chat_sessions")
}

model ChatMessage {
  id        String   @id @default(cuid())
  role      String   // "USER", "ASSISTANT", "SYSTEM"
  content   String
  sources   Json?    // Store citations and references
  metadata  Json?    // Store extra data like suggested questions
  createdAt DateTime @default(now())

  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([createdAt])
  @@map("chat_messages")
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ScheduleImportStatus {
  SUCCESS
  PARTIAL
  FAILED
}

model ScheduleActivity {
  id                  String     @id @default(cuid())
  activityId          String     // P6 activity_id
  name                String
  wbsCode             String?
  wbsName             String?
  plannedStart        DateTime?
  plannedFinish       DateTime?
  actualStart         DateTime?
  actualFinish        DateTime?
  durationDays        Float      @default(0)
  totalFloat          Float      @default(0)
  freeFloat           Float      @default(0)
  isCritical          Boolean    @default(false)
  riskScore           Float      @default(0)
  riskLevel           RiskLevel  @default(LOW)
  predecessors        Json?
  resourceAssignments Json?
  mitigationActions   Json?
  importId            String
  import              ScheduleImport @relation(fields: [importId], references: [id], onDelete: Cascade)
  projectId           String
  project             Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  changeOrders        ChangeOrder[]
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  @@index([projectId])
  @@index([importId])
  @@index([isCritical])
  @@index([riskLevel])
  @@index([riskScore])
  @@map("schedule_activities")
}

model ScheduleImport {
  id             String                @id @default(cuid())
  filename       String
  activityCount  Int                   @default(0)
  status         ScheduleImportStatus  @default(SUCCESS)
  errorMessage   String?
  projectId      String
  project        Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  activities     ScheduleActivity[]
  importedAt     DateTime              @default(now())

  @@index([projectId])
  @@index([importedAt])
  @@map("schedule_imports")
}

enum ProcurementStatus {
  IDENTIFIED
  RFQ
  PO_ISSUED
  IN_FABRICATION
  SHIPPED
  RECEIVED
  INSTALLED
}

model Vendor {
  id                 String   @id @default(cuid())
  name               String
  contactName        String?
  contactEmail       String?
  contactPhone       String?
  onTimeDeliveryRate Float    @default(100)
  qualityRate        Float    @default(100)
  complianceRate     Float    @default(100)
  overallScore       Float    @default(100)
  metadata           Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  projectId          String
  project            Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  items              ProcurementItem[]
  ncrs               Ncr[]
  inspections        Inspection[]

  @@index([projectId])
  @@map("vendors")
}

model ProcurementItem {
  id                 String            @id @default(cuid())
  poNumber           String?
  lineItem           String?
  material           String
  description        String?
  quantity           Float             @default(0)
  unit               String?
  status             ProcurementStatus @default(IDENTIFIED)
  orderDate          DateTime?
  promisedDate       DateTime?
  requiredOnSiteDate DateTime?
  actualDeliveryDate DateTime?
  metadata           Json?
  
  vendorId           String?
  vendor             Vendor?           @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  projectId          String
  project            Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([projectId])
  @@index([vendorId])
  @@index([status])
  @@index([requiredOnSiteDate])
  @@map("procurement_items")
}

enum RfiStatus {
  OPEN
  IN_REVIEW
  ANSWERED
  CLOSED
  VOID
}

enum RfiPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model Rfi {
  id               String       @id @default(cuid())
  number           String       // Project-scoped human reference, e.g. "RFI-0001"
  subject          String
  question         String
  status           RfiStatus    @default(OPEN)
  priority         RfiPriority  @default(MEDIUM)
  discipline       String?
  dueDate          DateTime?
  resolution       String?      // Official, human-approved answer
  suggestedAnswer  String?      // AI-generated draft (requires approval)
  suggestedSources Json?        // RAG citations backing the suggested answer
  suggestedAt      DateTime?
  answeredAt       DateTime?
  closedAt         DateTime?
  metadata         Json?

  projectId        String
  project          Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  raisedById       String
  raisedBy         User         @relation("RfiRaisedBy", fields: [raisedById], references: [id])
  assigneeId       String?
  assignee         User?        @relation("RfiAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  answeredById     String?
  answeredBy       User?        @relation("RfiAnsweredBy", fields: [answeredById], references: [id], onDelete: SetNull)
  documents        RfiDocument[]
  ncrs             Ncr[]

  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@unique([projectId, number])
  @@index([projectId])
  @@index([status])
  @@index([dueDate])
  @@index([assigneeId])
  @@map("rfis")
}

model RfiDocument {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())

  rfiId      String
  rfi        Rfi      @relation(fields: [rfiId], references: [id], onDelete: Cascade)
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([rfiId, documentId])
  @@index([rfiId])
  @@index([documentId])
  @@map("rfi_documents")
}

model AgentRun {
  id            String    @id @default(cuid())
  agentType     String
  status        String    @default("PENDING") // PENDING, RUNNING, COMPLETED, FAILED
  input         Json?
  output        Json?
  error         String?
  durationMs    Int?
  costEstimate  Float?
  projectId     String
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  triggeredById String?
  triggeredBy   User?     @relation(fields: [triggeredById], references: [id], onDelete: SetNull)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([projectId])
  @@index([agentType])
  @@index([status])
  @@map("agent_runs")
}

model AgentSchedule {
  id          String   @id @default(cuid())
  agentType   String
  schedule    String   // cron or interval: "daily", "weekly", "on-event"
  isActive    Boolean  @default(true)
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([projectId, agentType])
  @@index([projectId])
  @@map("agent_schedules")
}

enum ReportType {
  DAILY
  WEEKLY
  EXECUTIVE
  COMPLIANCE
  RISK
  PROCUREMENT
}

enum ReportStatus {
  PENDING
  GENERATING
  COMPLETED
  FAILED
}

model Report {
  id              String       @id @default(cuid())
  type            ReportType
  title           String
  status          ReportStatus @default(PENDING)
  markdownContent String?      // Full Markdown report content
  storageKey      String?      // MinIO object key for PDF
  fileSizeBytes   Int?
  error           String?
  metadata        Json?        // Section metadata, AI summary stats, etc.
  generatedAt     DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  projectId       String
  project         Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  generatedById   String?
  generatedBy     User?        @relation("ReportGeneratedBy", fields: [generatedById], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@map("reports")
}

enum SimulationStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model Simulation {
  id               String           @id @default(cuid())
  name             String
  description      String?
  targetActivityId String           // P6 activity_id
  delayDays        Int
  assumptions      Json?
  status           SimulationStatus @default(PENDING)
  impacts          Json?            // Nodes impacted, cascaded delay
  mitigationPlans  Json?            // Plans generated by MitigationPlannerAgent
  costImpact       Float?
  timeImpactDays   Int?
  error            String?
  
  projectId        String
  project          Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdById      String?
  createdBy        User?            @relation("SimulationCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([projectId])
  @@index([targetActivityId])
  @@map("simulations")
}

model NotificationPreference {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  inApp       Boolean  @default(true)
  emailDigest Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt


  @@map("notification_preferences")
}

// =============================================================================
// Task 018 — Advanced EPC Intelligence
// =============================================================================

// ---------------------------------------------------------------------------
// NCR (Non-Conformance Report)
// ---------------------------------------------------------------------------

enum NcrSeverity {
  MINOR
  MAJOR
  CRITICAL
}

enum NcrStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  CLOSED
  VOID
}

model Ncr {
  id               String      @id @default(cuid())
  number           String      // Project-scoped e.g. "NCR-0001"
  title            String
  description      String
  severity         NcrSeverity @default(MINOR)
  status           NcrStatus   @default(OPEN)
  discipline       String?
  rootCause        String?
  resolutionNote   String?
  resolvedAt       DateTime?
  closedAt         DateTime?
  metadata         Json?

  projectId        String
  project          Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  raisedById       String?
  raisedBy         User?       @relation("NcrRaisedBy", fields: [raisedById], references: [id], onDelete: SetNull)
  documentId       String?
  document         Document?   @relation(fields: [documentId], references: [id], onDelete: SetNull)
  rfiId            String?
  rfi              Rfi?        @relation(fields: [rfiId], references: [id], onDelete: SetNull)
  vendorId         String?
  vendor           Vendor?     @relation(fields: [vendorId], references: [id], onDelete: SetNull)

  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@unique([projectId, number])
  @@index([projectId])
  @@index([severity])
  @@index([status])
  @@index([raisedById])
  @@index([documentId])
  @@index([rfiId])
  @@index([vendorId])
  @@map("ncrs")
}

// ---------------------------------------------------------------------------
// Inspection / ITP (Inspection Test Plan)
// ---------------------------------------------------------------------------

enum InspectionStatus {
  SCHEDULED
  IN_PROGRESS
  PASSED
  FAILED
  ON_HOLD
  WAIVED
}

model Inspection {
  id              String           @id @default(cuid())
  itpRef          String?
  title           String
  discipline      String?
  holdPoint       Boolean          @default(false)
  inspector       String?
  scheduledDate   DateTime?
  completedDate   DateTime?
  status          InspectionStatus @default(SCHEDULED)
  result          String?
  vendorId        String?
  vendor          Vendor?          @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  documentId      String?
  document        Document?        @relation(fields: [documentId], references: [id], onDelete: SetNull)
  metadata        Json?

  projectId       String
  project         Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([projectId])
  @@index([status])
  @@index([scheduledDate])
  @@index([vendorId])
  @@index([documentId])
  @@map("inspections")
}

// ---------------------------------------------------------------------------
// Commissioning Record
// ---------------------------------------------------------------------------

enum CommissioningStatus {
  NOT_STARTED
  IN_PROGRESS
  PASSED
  FAILED
  CLOSED
}

model CommissioningRecord {
  id            String               @id @default(cuid())
  testRef       String?
  systemName    String
  discipline    String?
  status        CommissioningStatus  @default(NOT_STARTED)
  procedure     String?
  result        String?
  testedBy      String?
  completedDate DateTime?
  documentId    String?
  document      Document?            @relation(fields: [documentId], references: [id], onDelete: SetNull)
  metadata      Json?

  projectId     String
  project       Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@index([projectId])
  @@index([status])
  @@index([documentId])
  @@map("commissioning_records")
}

// ---------------------------------------------------------------------------
// Change Order
// ---------------------------------------------------------------------------

enum ChangeOrderStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  CANCELLED
}

model ChangeOrder {
  id                  String            @id @default(cuid())
  number              String
  title               String
  description         String
  reason              String?
  costImpact          Float             @default(0)
  scheduleImpactDays  Int               @default(0)
  status              ChangeOrderStatus @default(DRAFT)
  approvedById        String?
  approvedBy          User?             @relation("ChangeOrderApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt          DateTime?
  rejectedAt          DateTime?
  documentId          String?
  document            Document?         @relation(fields: [documentId], references: [id], onDelete: SetNull)
  scheduleActivityId  String?
  scheduleActivity    ScheduleActivity? @relation(fields: [scheduleActivityId], references: [id], onDelete: SetNull)
  metadata            Json?

  projectId           String
  project             Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@unique([projectId, number])
  @@index([projectId])
  @@index([status])
  @@index([approvedById])
  @@index([documentId])
  @@index([scheduleActivityId])
  @@map("change_orders")
}
