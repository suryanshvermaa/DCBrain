FROM node:20-slim

WORKDIR /app

# Native build tools required by bcrypt, sharp, etc.
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 \
    make \
    g++ \
    && rm -rf /var/lib/apt/lists/*

COPY package*.json ./
RUN npm install

COPY prisma ./prisma/
RUN npx prisma generate

COPY . .

EXPOSE 8000

CMD ["npm", "run", "dev"]
