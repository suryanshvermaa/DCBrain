# =============================================================================
# DCBrain — Production Environment Variables
# Copy this file to .env.prod and fill in all required values.
# NEVER commit .env.prod to git.
# =============================================================================

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=DCBrain
APP_ENV=production
APP_DEBUG=false
APP_VERSION=0.1.0
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_URL=https://dcbrain.example.com   # ← change to your domain

# ── Authentication ────────────────────────────────────────────────────────────
# REQUIRED: Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET_KEY=CHANGE_ME_GENERATE_A_64_BYTE_SECURE_HEX_KEY
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# REQUIRED
POSTGRES_USER=dcbrain
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_DB=dcbrain
DATABASE_URL=postgresql://dcbrain:CHANGE_ME_STRONG_DB_PASSWORD@postgres:5432/dcbrain

# ── Redis ─────────────────────────────────────────────────────────────────────
# REQUIRED — password-protect Redis in production
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_ME_STRONG_REDIS_PASSWORD@redis:6379/0

# ── MinIO (Object Storage) ────────────────────────────────────────────────────
MINIO_ACCESS_KEY=CHANGE_ME_MINIO_ACCESS_KEY
MINIO_SECRET_KEY=CHANGE_ME_MINIO_SECRET_KEY
MINIO_PUBLIC_URL=http://storage-dcbrain.nebula-hack.tech
MINIO_BUCKET_NAME=dcbrain-documents

# ── Neo4j (Knowledge Graph) ───────────────────────────────────────────────────
GRAPH_DB_URL=bolt://neo4j:7687
GRAPH_DB_USER=neo4j
GRAPH_DB_PASSWORD=CHANGE_ME_NEO4J_PASSWORD

# ── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# ── Google Gemini ─────────────────────────────────────────────────────────────
# REQUIRED: Get from Google AI Studio
GEMINI_API_KEY=CHANGE_ME_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0.05
GEMINI_MAX_TOKENS=2000

# ── Embeddings ────────────────────────────────────────────────────────────────
# REQUIRED: OpenAI API key used for document/chunk and query embeddings
OPENAI_API_KEY=CHANGE_ME_OPENAI_API_KEY
EMBEDDING_MODEL=text-embedding-3-small

# ── BullMQ Workers ────────────────────────────────────────────────────────────
BULLMQ_WORKER_CONCURRENCY=2

# ── Docker image registry ─────────────────────────────────────────────────────
REGISTRY=ghcr.io
IMAGE_PREFIX=your-org/dcbrain   # ← change to your GitHub org/user
IMAGE_TAG=latest

# ── Backup ────────────────────────────────────────────────────────────────────
BACKUP_DIR=/opt/dcbrain/backups
BACKUP_RETAIN_DAYS=30

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=warning
LOG_FORMAT=json

# ── Frontend (build-time args — used during docker build, not runtime) ────────
NEXT_PUBLIC_API_URL=https://dcbrain.example.com   # ← change to your domain
NEXT_PUBLIC_APP_NAME=DCBrain
