# Local test configuration for Application & Services
APP_NAME=DCBrain
APP_ENV=test
APP_DEBUG=true
APP_VERSION=0.1.0
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_URL=http://localhost:3020

JWT_SECRET_KEY=test_jwt_secret_key_change_for_production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

CHROMA_HOST=chromadb
CHROMA_PORT=8000

GEMINI_API_KEY=YOUR_TEST_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0.05
GEMINI_MAX_TOKENS=2000

EMBEDDING_MODEL=Xenova/bge-small-en-v1.5

BULLMQ_WORKER_CONCURRENCY=1

LOG_LEVEL=DEBUG
LOG_FORMAT=json

NEXT_PUBLIC_API_URL=http://localhost:8020
NEXT_PUBLIC_APP_NAME=DCBrain Test

# Admin config
